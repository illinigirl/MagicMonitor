# pnpm 11 prompts for approval on packages with install scripts. Sharp
# (image optimization) and unrs-resolver (Next.js' ESLint resolver) are
# both first-party trusted deps; whitelist their build scripts here so
# `pnpm install` and `pnpm dev` don't error out.
onlyBuiltDependencies[]=sharp
onlyBuiltDependencies[]=unrs-resolver

# Skip the pre-run install verification — it re-runs install before
# every `pnpm dev` and trips on the build-script gate.
verify-deps-before-run=false
