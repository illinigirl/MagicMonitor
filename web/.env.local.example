# Local-dev env for `pnpm dev` (Next.js on :3000).
# Production runs on Amplify SSR — those values are injected by CDK at
# build time (see infra/lib/disney-stack.ts → webApp.environmentVariables).
#
# Copy to .env.local and fill in. .env.local is gitignored.

# ─── DynamoDB ──────────────────────────────────────────────────────
# Local dev reads the same prod table the poller writes. SDK picks up
# AWS creds via AWS_PROFILE in your shell — no key/secret in this file.
AWS_REGION=us-east-2
DISNEY_TABLE_NAME=DisneyData
# Set this in your shell, not here, so it can vary by terminal:
#   export AWS_PROFILE=watchtower

# ─── Pushover (M3) ─────────────────────────────────────────────────
# SSR reads the app token from SSM at runtime to validate user-
# supplied user keys before saving. Only the PARAMETER NAME is in
# env — the secret value never leaves SSM. Same param the poller
# Lambda reads.
PUSHOVER_APP_TOKEN_PARAM=/disney/pushover/app_token

# ─── NextAuth / Cognito ────────────────────────────────────────────
# Auth.js v5 canonical names (AUTH_*) + v4-compat fallbacks (NEXTAUTH_*).
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Generate with:  openssl rand -base64 32
# In production, this comes from Secrets Manager (/magicmonitor/nextauth-secret).
AUTH_SECRET=<paste-32-byte-base64>
NEXTAUTH_SECRET=<paste-32-byte-base64>

# Tells Auth.js to trust X-Forwarded-Host on Amplify; harmless locally.
AUTH_TRUST_HOST=true

# Cognito pool + app client. Get values from CDK stack outputs:
#   aws cloudformation describe-stacks --stack-name DisneyStack \
#     --query "Stacks[0].Outputs" --region us-east-2 --profile watchtower
COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_ORhu761AY
COGNITO_CLIENT_ID=<from-DisneyStack.CognitoClientId-output>
COGNITO_DOMAIN_URL=https://auth.megillini.dev

# Cognito-managed app-client secret. Read with:
#   aws cognito-idp describe-user-pool-client \
#     --user-pool-id us-east-2_ORhu761AY \
#     --client-id <CognitoClientId> \
#     --region us-east-2 --profile watchtower \
#     --query 'UserPoolClient.ClientSecret' --output text
COGNITO_CLIENT_SECRET=<from-aws-cognito-idp-describe-user-pool-client>

# Public (browser-readable) duplicates for SignOutButton.tsx. Same
# values as above — Next requires the NEXT_PUBLIC_ prefix to expose
# them to client components.
NEXT_PUBLIC_COGNITO_DOMAIN_URL=https://auth.megillini.dev
NEXT_PUBLIC_COGNITO_CLIENT_ID=<same-as-COGNITO_CLIENT_ID>
