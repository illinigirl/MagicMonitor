# AWS region for DynamoDB queries
AWS_REGION=us-east-2

# DynamoDB table populated by the poller Lambda. Same table the
# infra/ stack creates — read its name from `cdk deploy` outputs.
DISNEY_TABLE_NAME=DisneyData

# In local dev, the AWS SDK picks up SSO credentials via AWS_PROFILE.
# Set this in your shell before `pnpm dev`:
#   export AWS_PROFILE=watchtower
# In production (Amplify SSR Lambda), the IAM role replaces this.
