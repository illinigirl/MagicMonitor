# CDK
infra/cdk.out/
infra/node_modules/
infra/*.d.ts
infra/*.js
infra/.cdk.staging/

# Next.js / web
web/node_modules/
web/.next/
web/out/
web/build/
web/.turbo/
web/tsconfig.tsbuildinfo
web/next-env.d.ts
# pnpm 10+ auto-generates this for build-script approval (its newer
# `allowBuilds:` field). It has no `packages:` field, which CI's pinned
# pnpm 9 rejects ("packages field missing or empty"). The real build
# config lives in web/package.json (pnpm.onlyBuiltDependencies), so this
# file is local-only noise — ignore it so a pnpm-11 dev can't re-commit it.
web/pnpm-workspace.yaml

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local env (never commit secrets)
.env
.env.local
.env.*.local

# Lambda asset bundling artifacts
infra/lambda/*/build/
infra/lambda/*/dist/

# Local debugging screenshots — never commit
*.jpeg
*.jpg
*.png
# …except the README portfolio shots, which are checked in.
!docs/screenshots/*.png

# Local-only scratch (Pi data dumps, etc — never committed)
.scratch/

# Session pickup / handoff notes — personal context, never committed.
PICKUP-*.md

# MCP server local venv (re-created via `pip install -r mcp/requirements.txt`)
mcp/.venv/
mcp/__pycache__/
